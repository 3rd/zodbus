{
  "name": "zodbus",
  "version": "0.0.0-semantic-release",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/3rd/zodbus.git"
  },
  "description": "Type-safe event bus built around Zod.",
  "keywords": [
    "event bus",
    "zod",
    "typescript"
  ],
  "author": {
    "name": "Andrei Neculaesei",
    "email": "3rd@users.noreply.github.com"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.3.11",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "tsdown",
    "publint": "publint --level=warning",
    "attw": "attw --pack .",
    "verify": "bun run test && bun run typecheck && bun run build && bun run publint && bun run attw",
    "tsc": "bun run typecheck",
    "benchmark": "cd benchmark && npm run benchmark",
    "release": "GIT_CONFIG_KEY_0=\"url.$(git remote get-url --push origin).insteadOf\" GIT_CONFIG_VALUE_0=\"https://github.com/3rd/zodbus.git\" GIT_CONFIG_COUNT=1 semantic-release --no-ci",
    "prepare": "husky",
    "prepublishOnly": "bun run verify"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  },
  "prettier": {
    "arrowParens": "always",
    "bracketSpacing": true,
    "printWidth": 120,
    "quoteProps": "as-needed",
    "semi": true,
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.20.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.1",
    "publint": "^0.3.21",
    "semantic-release": "^25.0.5",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "zod": "^4.1.11"
  }
}
